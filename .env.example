# 铁路售票系统环境变量配置示例
# 复制此文件为 .env 并填入实际值，或在启动时设置环境变量

# 数据库配置
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# JWT密钥配置（生产环境必须修改！）
# 建议使用随机生成的32位字符串，例如：openssl rand -base64 32
JWT_SECRET=change-me-in-production-32bytes!

# 可选：数据库URL（默认使用本地MySQL）
# DB_URL=jdbc:mysql://localhost:3306/railway_ticket_system?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&characterEncoding=utf8&useUnicode=true
